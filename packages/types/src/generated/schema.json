{
  "$defs": {
    "Announcement": {
      "additionalProperties": false,
      "description": "A dated, material AI-infrastructure announcement.\n\nSourced from primary filings (SEC 8-Ks, FERC dockets, company press\nreleases) and first-tier secondary outlets (Reuters, Bloomberg, FT,\nWSJ, Data Center Dynamics, Data Center Frontier). Every entry MUST\ncite a working ``source_url`` so the feed is auditable.\n\nThe five editorial categories cover the dominant news-flow shapes\nin AI-infra: ``deal`` (M&A, PPAs, leases, capex commitments),\n``launch`` (new sites breaking ground or going live), ``milestone``\n(capacity / performance / financing milestones for known projects),\n``opposition`` (community / regulatory pushback), and ``policy``\n(CHIPS Act, FERC rulings, moratoriums, tariffs, export controls).\n\nEither ``operator_id`` or ``datacenter_id`` is set when the entry\npins to a specific actor / site so the feed card can fly the map\nthere. Policy entries that span the whole industry leave both null.",
      "properties": {
        "amount_usd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount Usd"
        },
        "category": {
          "enum": [
            "deal",
            "launch",
            "milestone",
            "opposition",
            "policy"
          ],
          "title": "Category",
          "type": "string"
        },
        "datacenter_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Datacenter Id"
        },
        "date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "title": "Date",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "operator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator Id"
        },
        "source_url": {
          "title": "Source Url",
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Summary"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "id",
        "date",
        "title",
        "category",
        "source_url"
      ],
      "title": "Announcement",
      "type": "object"
    },
    "Cable": {
      "additionalProperties": false,
      "properties": {
        "capacity_tbps": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Capacity Tbps"
        },
        "geometry": {
          "additionalProperties": true,
          "title": "Geometry",
          "type": "object"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "landing_points": {
          "items": {
            "$ref": "#/$defs/CableLanding"
          },
          "title": "Landing Points",
          "type": "array"
        },
        "length_km": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Length Km"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "rfs_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Rfs Year"
        }
      },
      "required": [
        "id",
        "name",
        "length_km",
        "capacity_tbps",
        "landing_points",
        "geometry",
        "rfs_year"
      ],
      "title": "Cable",
      "type": "object"
    },
    "CableLanding": {
      "additionalProperties": false,
      "properties": {
        "coordinates": {
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "Coordinates",
          "type": "array"
        },
        "country": {
          "maxLength": 2,
          "minLength": 2,
          "title": "Country",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "country",
        "coordinates"
      ],
      "title": "CableLanding",
      "type": "object"
    },
    "CloudRegion": {
      "additionalProperties": false,
      "description": "Public cloud provider region.\n\nCloud providers do not publish exact datacenter coordinates for their\nregions for security reasons. We carry hand-curated metro-area\ncentroids and surface them as 10 km buffer circles in the UI so the\napproximation is explicit. ``source_url`` cites the provider's own\nregion documentation page for each row's existence and launch year.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "country": {
          "maxLength": 2,
          "minLength": 2,
          "title": "Country",
          "type": "string"
        },
        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "geometry": {
          "additionalProperties": true,
          "title": "Geometry",
          "type": "object"
        },
        "launch_year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Launch Year"
        },
        "provider": {
          "enum": [
            "aws",
            "azure",
            "gcp",
            "oracle",
            "alibaba"
          ],
          "title": "Provider",
          "type": "string"
        },
        "services": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Services"
        },
        "source_url": {
          "title": "Source Url",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "code",
        "display_name",
        "geometry",
        "country",
        "launch_year",
        "services",
        "source_url"
      ],
      "title": "CloudRegion",
      "type": "object"
    },
    "Datacenter": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "enum": [
            "verified",
            "osm_only",
            "press_release",
            "estimated"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "country": {
          "maxLength": 2,
          "minLength": 2,
          "title": "Country",
          "type": "string"
        },
        "est_mw_high": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Est Mw High"
        },
        "est_mw_low": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Est Mw Low"
        },
        "est_mw_mid": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Est Mw Mid"
        },
        "geometry": {
          "additionalProperties": true,
          "title": "Geometry",
          "type": "object"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "mw_source": {
          "anyOf": [
            {
              "enum": [
                "announcement",
                "utility-filing",
                "estimate"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Mw Source"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "operator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Operator Id"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Region"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "status": {
          "enum": [
            "operational",
            "construction",
            "announced",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        },
        "tier": {
          "enum": [
            "hyperscale",
            "colo",
            "neocloud",
            "enterprise"
          ],
          "title": "Tier",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "operator_id",
        "tier",
        "status",
        "geometry",
        "est_mw_low",
        "est_mw_mid",
        "est_mw_high",
        "mw_source",
        "country",
        "region",
        "sources",
        "confidence"
      ],
      "title": "Datacenter",
      "type": "object"
    },
    "Operator": {
      "additionalProperties": false,
      "properties": {
        "headquarters_country": {
          "maxLength": 2,
