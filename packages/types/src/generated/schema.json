          "title": "Fuel Type",
          "type": "string"
        },
        "geometry": {
          "additionalProperties": true,
          "title": "Geometry",
          "type": "object"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Operator"
        },
        "source": {
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "fuel_type",
        "capacity_mw",
        "geometry",
        "operator",
        "commissioning_year",
        "source"
      ],
      "title": "PowerPlant",
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
