# Copy to .env.local and fill in. Never commit real values.
# Used by `opendc tiles upload` and `opendc publish`.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket and public-base override (defaults: gigawattapp, no public URL emitted).
R2_BUCKET=gigawattapp
R2_PUBLIC_BASE=https://pub-<hash>.r2.dev/v1
