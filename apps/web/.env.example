# Copy to .env.local and fill in. Never commit real values.

# Base URL of the PMTiles archive directory on R2 (no trailing slash).
# Example: https://pub-<hash>.r2.dev/v1
# When unset the map falls back to bundled seed GeoJSON (dev mode).
NEXT_PUBLIC_PMTILES_BASE=

# Full public URL of the announcements JSON artifact on R2.
# Example: https://pub-<hash>.r2.dev/v1/announcements.json
# When unset the UI falls back to bundled seed JSON (dev mode).
NEXT_PUBLIC_ANNOUNCEMENTS_URL=

# Full public URL of the search-index JSON artifact on R2 (Cmd+K palette).
# Example: https://pub-<hash>.r2.dev/v1/search-index.json
# When unset the palette falls back to bundled seed JSON (dev mode).
NEXT_PUBLIC_SEARCH_INDEX_URL=

# Full public URL of the downloads manifest JSON on R2 (powers /data page).
# Example: https://pub-<hash>.r2.dev/v1/downloads/manifest.json
# When unset the /data page shows an empty-state message.
NEXT_PUBLIC_MANIFEST_URL=

# Origin of the Worker API (no trailing slash). Powers the ticker panel and
# any other client-side fetch to /api/v1/*.
# Local dev: http://localhost:8787 (default `wrangler dev` port).
# Production: leave empty so requests stay same-origin behind Cloudflare.
NEXT_PUBLIC_API_BASE=

# Canonical absolute origin of the deployed site (no trailing slash). Used to
# build absolute URLs in openGraph / twitter metadata so unfurlers (Slack,
# LinkedIn, iMessage) can resolve the OG image.
# Defaults to https://gigawattmap.com when unset; override on preview deploys.
NEXT_PUBLIC_APP_URL=
